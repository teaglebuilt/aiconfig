{
  "name": "schema_infer",
  "description": "Analyze existing notes and suggest a Picoschema definition.",
  "arguments": {
    "type": "object",
    "properties": {
      "note_type": {
        "type": "string"
      },
      "threshold": {
        "default": 0.25,
        "type": "number"
      },
      "project": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "workspace": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "output_format": {
        "default": "text",
        "enum": [
          "text",
          "json"
        ],
        "type": "string"
      }
    },
    "required": [
      "note_type"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "required": [
      "result"
    ],
    "x-fastmcp-wrap-result": true
  }
}