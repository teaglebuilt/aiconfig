{
  "name": "read_note",
  "description": "Read a markdown note by title or permalink.",
  "arguments": {
    "type": "object",
    "properties": {
      "identifier": {
        "type": "string"
      },
      "project": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "workspace": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "page": {
        "default": 1,
        "type": "integer"
      },
      "page_size": {
        "default": 10,
        "type": "integer"
      },
      "output_format": {
        "default": "text",
        "enum": [
          "text",
          "json"
        ],
        "type": "string"
      },
      "include_frontmatter": {
        "default": false,
        "type": "boolean"
      }
    },
    "required": [
      "identifier"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "required": [
      "result"
    ],
    "x-fastmcp-wrap-result": true
  }
}