{
  "name": "write_note",
  "description": "Create a markdown note. If the note already exists, returns an error by default — pass overwrite=True to replace.",
  "arguments": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string"
      },
      "content": {
        "type": "string"
      },
      "directory": {
        "type": "string"
      },
      "project": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "workspace": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "tags": {
        "anyOf": [
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "note_type": {
        "default": "note",
        "type": "string"
      },
      "metadata": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "overwrite": {
        "anyOf": [
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "output_format": {
        "default": "text",
        "enum": [
          "text",
          "json"
        ],
        "type": "string"
      }
    },
    "required": [
      "title",
      "content",
      "directory"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "required": [
      "result"
    ],
    "x-fastmcp-wrap-result": true
  }
}